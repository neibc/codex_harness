# Codex harness — gitignore

# 중간 산출물 (오케스트레이터의 작업 영역)
_workspace/
_workspace_prev_*/

# MCP 팀 서버 빌드 산출물
mcp-team-server/node_modules/
mcp-team-server/dist/
mcp-team-server/*.log

# Codex 로컬 상태 (사용자별)
.codex/
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm

# OS / 에디터
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# Node
package-lock.json.backup
yarn.lock.backup
.pnpm-store/

# 테스트 임시
tests/_tmp/
tests/_results/
