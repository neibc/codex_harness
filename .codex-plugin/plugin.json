{
  "name": "codex-harness",
  "version": "0.1.0",
  "description": "Agent Team & Skill Architect — Codex CLI port of revfactory/harness 1.2.0.",
  "author": {
    "name": "codex_harness contributors",
    "url": "https://github.com/revfactory/codex_harness"
  },
  "homepage": "https://github.com/revfactory/codex_harness",
  "repository": "https://github.com/revfactory/codex_harness",
  "license": "Apache-2.0",
  "keywords": [
    "harness",
    "agent-team",
    "skill-architect",
    "meta-skill",
    "orchestration",
    "codex"
  ],
  "skills": "./skills/",
  "hooks": "./hooks/hooks.json",
  "mcpServers": "./.mcp.json",
  "interface": {
    "displayName": "codex-harness",
    "shortDescription": "Meta-skill that designs agent teams and generates skills, ported to Codex.",
    "category": "Productivity",
    "capabilities": ["Interactive", "Write"],
    "defaultPrompt": [
      "/harness 새 도메인의 하네스를 구성해줘",
      "/harness 기존 하네스를 점검해줘",
      "/harness 에이전트와 스킬을 동기화해줘"
    ]
  }
}
