{
  "name": "codex-harness",
  "version": "0.3.0",
  "description": "The team-architecture factory for Codex CLI. Designs multi-agent teams and generates skills — six patterns: Pipeline, Fan-out/Fan-in, Expert Pool, Producer-Reviewer, Supervisor, Hierarchical Delegation. Codex port of revfactory/harness.",
  "author": {
    "name": "codex_harness contributors",
    "url": "https://github.com/neibc/codex_harness"
  },
  "homepage": "https://github.com/neibc/codex_harness",
  "repository": "https://github.com/neibc/codex_harness",
  "license": "Apache-2.0",
  "keywords": [
    "harness",
    "harness-factory",
    "team-architecture-factory",
    "agent-team",
    "multi-agent",
    "skill-architect",
    "meta-skill",
    "orchestration",
    "codex-plugin",
    "codex",
    "pipeline",
    "fan-out-fan-in",
    "expert-pool",
    "producer-reviewer",
    "supervisor",
    "hierarchical-delegation",
    "mcp-team-server"
  ],
  "skills": "./skills/",
  "mcpServers": "./.mcp.json",
  "interface": {
    "displayName": "codex-harness",
    "shortDescription": "The team-architecture factory — designs agent teams & generates skills. Codex port of revfactory/harness.",
    "category": "Productivity",
    "capabilities": ["Interactive", "Write"],
    "defaultPrompt": [
      "하네스를 구성해줘",
      "하네스를 점검해줘",
      "에이전트와 스킬을 동기화해줘"
    ]
  }
}
